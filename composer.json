{
    "name": "niklasschmitt/laravel-saml2",
    "description": "SAML2 Service Provider integration for Laravel applications, based on OneLogin toolkit",
    "type": "library",
    "keywords": ["laravel", "saml", "saml2", "onelogin", "sso"],
    "homepage": "https://github.com/NiklasSchmitt/laravel-saml2",
    "license": "MIT",
    "authors": [
        {
            "name": "Niklas Schmitt",
            "email": "niklas.schmitt@hs-fulda.de"
        },
        {
            "name": "Artem Brezhnev",
            "email": "brezzhnev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-openssl": "*",
        "illuminate/console": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "onelogin/php-saml": "^4.3.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "NiklasSchmitt\\Saml2\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Saml2": "NiklasSchmitt\\Saml2\\Facades\\Auth"
            },
            "providers": [
                "NiklasSchmitt\\Saml2\\ServiceProvider"
            ]
        }
    },
    "conflict": {
        "onelogin/php-saml": "<4.3.1",
        "24slides/laravel-saml2": "*",
        "niklasschmitt/laravel-saml2": "<2.5.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
